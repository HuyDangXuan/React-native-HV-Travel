    "models/Tour.ts",
    "models/Notification.ts",
    "utils/inboxNotifications.ts",
    "utils/loadingState.ts",
    "utils/pullToRefresh.ts",
    "utils/tourSearch.ts",
    "utils/tourDetail.ts",
    "services/AccountStorageService.ts",
    "services/ApiService.ts",
    "services/AuthSessionService.ts",
    "services/AuthService.ts",
    "services/ChatbotService.ts",
    "services/dataAdapters.ts",
    "validators/authSchema.ts"
  ]
}
